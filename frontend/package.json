{
  "name": "whatsthedamage-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite serve",
    "build": "vite build",
    "build:prod": "VITE_API_BASE_URL=/api/v2 vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:all": "npm run lint && npm run type-check && npm run knip && npm run test",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --ext .ts,.js,.vue",
    "type-check": "tsc --noEmit",
    "format": "prettier --write .",
    "gettext-extract": "vue-gettext-extract",
    "gettext-compile": "vue-gettext-compile",
    "knip": "knip",
    "check-updates": "npm-check-updates -u --upgradeInterval never"
  },
  "dependencies": {
    "@popperjs/core": "^2.11.8",
    "bootstrap": "^5.3.8",
    "chart.js": "^4.5.1",
    "pinia": "^3.0.4",
    "vue": "^3.5.34",
    "vue-chartjs": "^5.3.3",
    "vue-router": "^5.0.7",
    "vue3-gettext": "^4.0.0-beta.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bootstrap": "^5.2.10",
    "@types/jsdom": "^28.0.3",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/ui": "^4.1.7",
    "@vue/compiler-sfc": "^3.5.34",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-pinia": "^0.4.2",
    "eslint-plugin-vue": "^10.9.1",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "knip": "^6.14.2",
    "npm-check-updates": "^22.2.0",
    "prettier": "^3.8.3",
    "terser": "^5.48.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vite": "^8.0.14",
    "vitest": "^4.1.7",
    "vue-eslint-parser": "^10.4.0"
  }
}
